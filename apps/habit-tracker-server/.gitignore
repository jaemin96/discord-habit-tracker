# NestJS specific build output
dist/

# Environment variables (NestJS specific configs)
.env
.env.*.local

# NestJS test coverage
coverage/

# NestJS debug files
tsconfig.build.tsbuildinfo

# Upload directories (if using file uploads)
uploads/
temp/

# Database files (if using local SQLite for dev)
*.db-journal

# Supabase local/dev artifacts
supabase/.temp/
supabase/.branches/
supabase/config.local.toml

# Prisma local/generated artifacts
prisma/dev.db
prisma/dev.db-journal
prisma/*.db
prisma/*.db-journal
prisma/generated/

# Session storage
sessions/

# PM2 logs (if using PM2 for deployment)
.pm2/

# NestJS CLI
.nest-cli.json.cache
